# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=765591222

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AI Models
AI_LITE_MODEL=meta-llama/llama-3.1-8b-instruct:free
AI_PRO_MODEL=anthropic/claude-3.5-sonnet
AI_IMAGE_MODEL=openai/dall-e-3

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/auto_smm
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/auto_smm

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App Settings
DEBUG=False
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_here

# Webhook (optional, for production)
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_PATH=/webhook
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
